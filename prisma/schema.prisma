// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============== USER WITH MEMBERSHIP ==============

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   DateTime? @map("email_verified")
  name            String?
  password        String?  // Hashed - optional for OAuth users
  image           String?
  phone           String?
  role            Role     @default(USER)
  
  // Membership
  membershipTier  MembershipTier @default(NONE)  // NONE = no discount, MEMBER = 30% off
  
  // Relations
  accounts        Account[]
  sessions        Session[]
  reviews         Review[]
  watchlist       Watchlist[]
  bookings        Booking[]
  adminAuditLogs  AdminAuditLog[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("users")
}

// ============== ADMIN AUDIT LOGGING ==============

model AdminAuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // LOGIN, LOGOUT, CREATE, UPDATE, DELETE, etc.
  details   String?  // Additional details about the action
  timestamp DateTime @default(now())
  ipAddress String?  // IP address for security tracking
  userAgent String?  // Browser/user agent info
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([timestamp])
  @@map("admin_audit_logs")
}

// ============== CORE ENTITIES ==============

model Movie {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  releaseDate DateTime?
  duration    Int?      // in minutes
  rating      Decimal?  @db.Decimal(2, 1) // 0.0 - 10.0
  posterUrl   String?
  backdropUrl String?
  language    String    @default("en")
  status      MovieStatus @default(RELEASED)
  
  // Relations
  genres      Genre[]
  cast        CastMember[]
  reviews     Review[]
  watchlists  Watchlist[]
  showtimes   Showtime[]  // When this movie is scheduled
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Genre {
  id     String  @id @default(uuid())
  name   String  @unique
  slug   String  @unique
  movies Movie[]
}

model Person {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  birthDate   DateTime?
  photoUrl    String?
  biography   String?  @db.Text
  nationality String?
  cast        CastMember[]
}

model CastMember {
  id            String    @id @default(uuid())
  movieId       String
  personId      String
  role          CastRole
  characterName String?   // Only for actors
  
  movie         Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person        Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  
  @@unique([movieId, personId, role, characterName])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-10
  content   String?  @db.Text
  movieId   String
  userId    String
  
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([movieId, userId])
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  watched   Boolean  @default(false)
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, movieId])
}

// ============== CINEMA & SHOWTIMES ==============

model Hall {
  id          String   @id @default(uuid())
  name        String   // "Hall 1", "IMAX 1", "VIP Room"
  capacity    Int
  hallType    HallType @default(STANDARD)
  columns     Int      @default(10)      // Number of columns in the grid
  isActive    Boolean  @default(true)
  isPublished Boolean  @default(false)   // Locks configuration when true
  publishedAt DateTime?                   // When the hall was published
  version     Int      @default(1)       // For optimistic locking
  
  // Relations
  showtimes   Showtime[]
  seats       Seat[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Showtime {
  id                String   @id @default(uuid())
  movieId           String
  hallId            String
  startTime         DateTime
  endTime           DateTime
  basePrice         Decimal  @db.Decimal(10, 2)
  
  // Weekend Pricing
  isWeekend         Boolean  @default(false)  // Auto-calculated from startTime
  weekendMultiplier Decimal  @default(1.3)    // 30% increase on weekends
  
  status            ShowtimeStatus @default(ACTIVE)
  
  // Relations
  movie             Movie    @relation(fields: [movieId], references: [id])
  hall              Hall     @relation(fields: [hallId], references: [id])
  bookings          Booking[]
  tickets           Ticket[]
  
  createdAt         DateTime @default(now())
  
  @@index([startTime])
  @@index([movieId])
}

// ============== SEATING & BOOKING ==============

model Seat {
  id            String      @id @default(uuid())
  hallId        String
  row           String      // "A", "B", "AA" - row label
  column        Int         // 0-based grid coordinate
  seatNumber    Int?        // Display number (null if inactive)
  seatType      SeatType    @default(REGULAR)
  status        SeatStatus  @default(AVAILABLE)
  linkedSeatId  String?     // Links LOVESEAT_LEFT ↔ LOVESEAT_RIGHT
  
  // Relations
  hall          Hall        @relation(fields: [hallId], references: [id])
  tickets       Ticket[]
  
  @@unique([hallId, row, column])
  @@index([hallId, status])
  @@index([linkedSeatId])
}

model Booking {
  id              String   @id @default(uuid())
  userId          String
  showtimeId      String
  
  // Pricing Summary
  subtotal        Decimal  @db.Decimal(10, 2)  // Sum of all ticket originalPrice
  totalDiscount   Decimal  @db.Decimal(10, 2)  // Sum of all discounts
  finalAmount     Decimal  @db.Decimal(10, 2)  // subtotal - totalDiscount
  
  bookingStatus   BookingStatus @default(PENDING)
  
  // Relations
  user            User     @relation(fields: [userId], references: [id])
  showtime        Showtime @relation(fields: [showtimeId], references: [id])
  tickets         Ticket[]
  payment         Payment?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

model Ticket {
  id              String   @id @default(uuid())
  bookingId       String
  showtimeId      String
  seatId          String
  ticketType      TicketType @default(ADULT)
  
  // Pricing (calculated at booking time)
  originalPrice   Decimal  @db.Decimal(10, 2)  // basePrice * weekendMultiplier
  discountAmount  Decimal  @db.Decimal(10, 2)  // 30% if user is member
  finalPrice      Decimal  @db.Decimal(10, 2)  // originalPrice - discountAmount
  
  status          TicketStatus @default(RESERVED)
  
  // Relations
  booking         Booking  @relation(fields: [bookingId], references: [id])
  showtime        Showtime @relation(fields: [showtimeId], references: [id])
  seat            Seat     @relation(fields: [seatId], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@unique([showtimeId, seatId])
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  
  // Relations
  booking       Booking  @relation(fields: [bookingId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============== ENUMS ==============

enum Role {
  USER
  ADMIN
  MANAGER
}

enum MembershipTier {
  NONE      // 0% discount
  MEMBER    // 30% discount
}

enum MovieStatus {
  ANNOUNCED
  POST_PRODUCTION
  RELEASED
  CANCELLED
}

enum HallType {
  STANDARD
  VIP
}

enum ShowtimeStatus {
  ACTIVE
  CANCELLED
  SOLD_OUT
  COMPLETED
}

enum CastRole {
  ACTOR
  DIRECTOR
  WRITER
  PRODUCER
}

enum SeatType {
  REGULAR
  VIP
  LOVESEAT_LEFT
  LOVESEAT_RIGHT
}

enum SeatStatus {
  AVAILABLE
  SELECTED
  BOOKED
  RESERVED
  INACTIVE
  BLOCKED
}

enum TicketType {
  ADULT
  CHILD
  STUDENT
  SENIOR
}

enum TicketStatus {
  RESERVED
  CONFIRMED
  CANCELLED
  USED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  MOBILE_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============== AUTH.JS MODELS ==============

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}
